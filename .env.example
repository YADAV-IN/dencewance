# Copy this to .env and fill the values. Never commit your real .env to git.

# Appwrite (optional once fully migrated)
APPWRITE_ENDPOINT=https://nyc.cloud.appwrite.io/v1
APPWRITE_PROJECT_ID=69d60fbe002bae1e32d5
APPWRITE_API_KEY=
APPWRITE_DB_ID=69d60fe8000c9bd92750
APPWRITE_BUCKET_ID=alok_media

# Cloudflare R2 (required for migration)
R2_ACCOUNT_ID=
R2_ACCESS_KEY_ID=
R2_SECRET_ACCESS_KEY=
R2_BUCKET_NAME=
R2_PUBLIC_URL=https://<your-cdn-or-bucket-domain> # e.g. https://media.example.com (optional)

# JWT secret used by backend
JWT_SECRET=change_me_in_production

# Other useful envs
PORT=4000
NODE_ENV=development
